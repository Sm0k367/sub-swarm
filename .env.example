# EchoCodex 2026 — Environment Variables
# Add these in Vercel Dashboard before deploying

# OpenAI (required for Echo Fusion Lab)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Replicate (for future video generation features)
REPLICATE_API_TOKEN=r8-your-replicate-token-here

# Optional: Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# App URL (used for OG images and metadata)
NEXT_PUBLIC_APP_URL=https://echocodex.vercel.app
